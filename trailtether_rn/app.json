{
  "expo": {
    "name": "Trailtether",
    "slug": "trailtether-rn",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "trailtether",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/hero_mountain.png",
      "resizeMode": "cover",
      "backgroundColor": "#07090c"
    },
    "android": {
      "package": "com.trailtether.rn",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#07090c"
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.trailtether.rn"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
