# ============================================================================
# Hilltrek — Apache config for static hosting on cPanel
# ============================================================================

# 0. Origin lockdown — require Cloudflare's auth header on every request.
#    CF adds X-Hilltrek-CF-Auth via a Request Header Transform Rule.
#    Direct attackers hitting origin (102.222.124.20) don't have the header → 403.
#    /.well-known/ is exempted so any ACME / Let's Encrypt HTTP-01 challenges
#    keep working if Aserv ever needs to renew the origin cert.
#    To rotate the secret: update the Transform Rule in Cloudflare AND this line.
RewriteEngine On
RewriteCond %{REQUEST_URI} !^/\.well-known/
RewriteCond %{HTTP:X-Hilltrek-CF-Auth} !^hk-cf-origin-a8d2e6b9f3c1054782b9e3f6d8a1c2e5$
RewriteRule .* - [F,L]

# 1. Force HTTPS (RewriteEngine already on from section 0)
RewriteCond %{HTTPS} !=on
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# 2. Redirect the old Sitejet /trailtether-app/ URL to the new /trailtether/
RewriteRule ^trailtether-app/?$ /trailtether/ [R=301,L]
RewriteRule ^trailtether-app/(.*)$ /trailtether/$1 [R=301,L]

# 3. Clean URLs — let /hikes/ serve /hikes/index.html (Apache does this by
#    default with DirectoryIndex, but make it explicit)
DirectoryIndex index.html

# 4. Custom 404
ErrorDocument 404 /404.html

# 5. Compression — speeds up everything
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# 6. Cache static assets aggressively (CSS/JS get versioned via filename so
#    long cache is safe; images don't change often)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css                "access plus 7 days"
  ExpiresByType application/javascript  "access plus 7 days"
  ExpiresByType image/jpeg              "access plus 30 days"
  ExpiresByType image/png               "access plus 30 days"
  ExpiresByType image/webp              "access plus 30 days"
  ExpiresByType image/x-icon            "access plus 30 days"
  ExpiresByType text/html               "access plus 0 seconds"
</IfModule>

# 7. Security headers
#
# CSP allowlist mirrors the admin SPA's policy + adds Cloudflare Turnstile
# endpoints (the APK gate widget). 'unsafe-inline' on scripts is required
# by the existing inline IIFEs on /trailtether/ and a few page-level setters
# (year, etc.) — moving to nonces/hashes would let us drop it later but
# isn't blocking the rest of the hardening pass.
#
# HSTS: 2 years + includeSubDomains + preload, so the domain can be
# submitted to https://hstspreload.org and shipped baked into every browser.
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://challenges.cloudflare.com https://*.supabase.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https://*.supabase.co https://hilltrek.co.za https://*.hilltrek.co.za; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://cdn.jsdelivr.net https://challenges.cloudflare.com https://api.open-meteo.com https://api.bigdatacloud.net; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
</IfModule>
